# Apache configuration file (see https://httpd.apache.org/docs/current/mod/quickreference.html)
Require all granted

# disable directory listing
<IfModule mod_autoindex.c>
	Options -Indexes
</IfModule>

# enable cool URL
<IfModule mod_rewrite.c>
	RewriteEngine On
	# RewriteBase /

	# legacy URLs from old PHP admin (?page=...)
	RewriteCond %{QUERY_STRING} ^page=families-update&id=([0-9]+)&address=1(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /family/update/%1?tab=info [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=families-update&id=([0-9]+)&proposal=1(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /family/update/%1?tab=proposals [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=families-update&id=([0-9]+)&contract=1(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /family/update/%1?tab=contracts [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=families-update&id=([0-9]+)&order=1(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /family/update/%1?tab=orders [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=opatrovatelky-update&id=([0-9]+)&address=1(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /babysitter/update/%1?tab=info [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=opatrovatelky-update&id=([0-9]+)&education=1(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /babysitter/update/%1?tab=education [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=opatrovatelky-update&id=([0-9]+)&profil=1(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /babysitter/update/%1?tab=profil [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=opatrovatelky-update&id=([0-9]+)&work-profile=1(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /babysitter/update/%1?tab=work-profile [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=opatrovatelky-update&id=([0-9]+)&documents=1(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /babysitter/update/%1?tab=documents [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=opatrovatelky-update&id=([0-9]+)&pdf=1(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /babysitter/update/%1?tab=pdf [R=301,L]

	RewriteCond %{QUERY_STRING} ^page=families-update&id=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /family/update/%1 [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=opatrovatelky-update&id=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /babysitter/update/%1 [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=partneri-update&id=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /partner/update/%1 [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=partneri-update=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /partner/update/%1 [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=opatrovanie-update&id=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /partner/update/%1 [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=agencies-update&id=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /agency/update/%1 [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=country-update&id=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /country/update/%1 [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=turnus-update&id=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /turnus/update/%1 [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=todo-update&id=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /todo/update/%1 [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=proposal-update&id=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /proposal/update/%1 [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=user-management-update&id=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /user-management/update/%1 [R=301,L,QSD]

	RewriteCond %{QUERY_STRING} ^page=turnus-records-month&year=([0-9]{4})&month=([0-9]{1,2})(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /turnus/month?year=%1&month=%2 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=turnus-records-month&year([0-9]{4})&month=([0-9]{1,2})(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /turnus/month?year=%1&month=%2 [R=301,L]

	RewriteCond %{QUERY_STRING} ^page=families&user=([0-9]+)&status=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /family?user=%1&status=%2 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=projekty&user=([0-9]+)&status=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /project?user=%1&status=%2 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=turnus&order=([0-9]+)&finish=([0-9]+)&status=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /turnus?order=%1&finish=%2&status=%3 [R=301,L]

	RewriteCond %{QUERY_STRING} ^page=families&country=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /family?country=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=families&partner=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /family?partner=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=families&user=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /family?user=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=families&status=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /family?status=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=projekty&country=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /project?country=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=projekty&partner=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /project?partner=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=projekty&user=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /project?user=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=(?:projekty|proejekty)&status=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /project?status=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=opatrovatelky&gender=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /babysitter?gender=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=opatrovatelky&country=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /babysitter?country=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=opatrovatelky&agency=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /babysitter?agency=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=opatrovatelky&status=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /babysitter?status=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=pracovnici&gender=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /worker?gender=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=pracovnici&country=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /worker?country=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=pracovnici&agency=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /worker?agency=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=pracovnici&status=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /worker?status=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=partneri&country=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /partner?country=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=partneri&status=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /partner?status=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=agencies&country=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /agency?country=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=agencies&status=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /agency?status=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=turnus&finish=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /turnus?finish=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=turnus&status=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /turnus?status=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=turnus&order=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /turnus?order=%1 [R=301,L]
	RewriteCond %{QUERY_STRING} ^page=todo&status=([0-9]+)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /todo?status=%1 [R=301,L]

	RewriteCond %{QUERY_STRING} ^page=(?:homepage|dokumenty)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ / [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=logout(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /logout/ [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=stats(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /stats [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=settings(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /settings [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=missing-registry(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /missing-registry [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=country(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /country [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=translation(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /translation [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=user-management(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /user-management [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=families(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /family [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=(?:projekty|proejekty|offcanvasProject)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /project [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=opatrovatelky(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /babysitter [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=pracovnici(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /worker [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=(?:partneri|opatrovanie|offcanvasPartner)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /partner [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=agencies(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /agency [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=turnus(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /turnus [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=turnus-select-month(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /turnus/select-month [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=(?:proposal|proposal-records)(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /proposal [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=todo(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /todo [R=301,L,QSD]
	RewriteCond %{QUERY_STRING} ^page=offcanvasFamily(?:&.*)?$ [NC]
	RewriteRule ^(?:index\.php)?$ /family [R=301,L,QSD]


    # RewriteCond %{HTTP_HOST} ^local.sk
    # RewriteRule (.*) https://www.local.sk/$1 [R=301,L]

	# use HTTPS
	# RewriteCond %{HTTPS} !on
	# RewriteRule .? https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

	# prevents files starting with dot to be viewed by browser
	RewriteCond %{REQUEST_FILENAME} -f
	RewriteRule /\.|^\.(?!well-known/) - [F]

	# front controller
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule !\.(pdf|js|mjs|ico|gif|jpg|jpeg|png|webp|svg|css|rar|zip|7z|tar\.gz|map|eot|ttf|otf|woff|woff2)$ index.php [L]
</IfModule>

# security headers
<IfModule mod_headers.c>
	Header always set X-Frame-Options "DENY"
	Header always set X-Content-Type-Options "nosniff"
	Header always set Referrer-Policy "strict-origin-when-cross-origin"
	Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
	# HSTS — povoliť az po nasadeni produkcneho HTTPS (v dev mode nema zmysel):
	# Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
	# CSP — postupne zaviest po inventarizacii zdrojov (najprv v report-only mode):
	# Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data:;"
</IfModule>

# enable gzip compression
<IfModule mod_deflate.c>
	<IfModule mod_filter.c>
		AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json application/xml image/svg+xml
	</IfModule>
</IfModule>
