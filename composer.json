{
	"require": {
		"php": ">= 8.5",
		"nette/application": "^3.2",
		"nette/bootstrap": "^3.2",
		"nette/caching": "^3.4",
		"nette/database": "^3.2",
		"nette/di": "^3.2",
		"nette/forms": "^3.2",
		"nette/http": "^3.3",
		"nette/mail": "^4.0",
		"nette/robot-loader": "^4.1",
		"nette/security": "^3.2",
		"nette/utils": "^4.1",
		"latte/latte": "^3.1",
		"tracy/tracy": "^2.11",
		"guzzlehttp/guzzle": "^7.10",
		"vlucas/phpdotenv": "^5.6",
		"contributte/console": "^0.10",
		"psr/clock": "^1.0",
		"ext-simplexml": "*"
	},
	"require-dev": {
		"nette/tester": "^2.6",
		"phpunit/phpunit": "^12.5",
		"mockery/mockery": "^1.6",
		"symfony/thanks": "^1.4",
		"phpstan/phpstan": "^2.1",
		"phpstan/phpstan-nette": "^2.0"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests"
		}
	},
	"minimum-stability": "stable",
	"config": {
		"allow-plugins": {
			"symfony/thanks": true
		},
		"platform": {
			"php": "8.5"
		}
	}
}